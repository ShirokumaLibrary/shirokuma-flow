{
  "name": "@shirokuma-library/context",
  "version": "0.3.0-alpha.154",
  "description": "External documentation fetching CLI for shirokuma workflows.",
  "type": "module",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "shirokuma-context": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shirokuma-library/lint": "workspace:*",
    "commander": "^12.1.0",
    "turndown": "^7.2.2",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@shirokuma-library/dev-preset": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShirokumaDevelopment/shirokuma-docs.git",
    "directory": "packages/context"
  },
  "publishConfig": {
    "access": "public"
  }
}
