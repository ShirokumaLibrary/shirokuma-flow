#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules/dependency-cruiser/bin/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules/dependency-cruiser/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules/dependency-cruiser/bin/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules/dependency-cruiser/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules/dependency-cruiser/bin/wrap-stream-in-html.mjs" "$@"
else
  exec node  "$basedir/../../../../node_modules/.pnpm/dependency-cruiser@17.3.7/node_modules/dependency-cruiser/bin/wrap-stream-in-html.mjs" "$@"
fi
