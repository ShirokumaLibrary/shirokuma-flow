<div class="max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">{{name}}</h1>
      {{#if description}}
      <p class="text-gray-500 text-sm mt-1">{{description}}</p>
      {{/if}}
      <p class="text-gray-400 text-xs mt-1">{{summary.totalTools}} ツール &middot; {{summary.totalCategories}} カテゴリ</p>
    </div>
    <span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded uppercase font-medium">{{protocol}}</span>
  </div>

  <!-- カテゴリ別ツール -->
  {{#each toolsByCategory}}
  <div class="mb-6">
    <h2 class="text-base font-semibold text-gray-900 mb-3">
      {{this.name}}
      {{#if this.description}}
      <span class="text-sm text-gray-500 font-normal ml-2">{{this.description}}</span>
      {{/if}}
    </h2>
    <div class="space-y-2">
      {{#each this.toolItems}}
      <details class="bg-white rounded-lg border border-gray-200 group">
        <summary class="flex items-center justify-between p-3 cursor-pointer list-none hover:bg-gray-50 rounded-lg">
          <span class="font-mono text-sm text-gray-900">{{this.name}}</span>
          <div class="flex gap-2 items-center">
            {{#if this.authLevel}}
            <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded">{{this.authLevel}}</span>
            {{/if}}
            <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="px-4 pb-3 border-t border-gray-100 pt-2">
          <p class="text-sm text-gray-600">{{this.description}}</p>
          {{#if this.inputSchema}}
          {{#ifNotEmpty this.inputSchema.properties}}
          <div class="mt-2">
            <div class="text-xs font-semibold text-gray-500 mb-1">パラメーター</div>
            <table class="w-full text-xs">
              <tbody class="divide-y divide-gray-100">
                {{#each (entries this.inputSchema.properties)}}
                <tr>
                  <td class="py-1 font-mono text-gray-900">{{this.key}}</td>
                  <td class="py-1 text-blue-700 px-2">{{this.value.type}}</td>
                  <td class="py-1 text-gray-500">{{this.value.description}}</td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
          {{/ifNotEmpty}}
          {{/if}}
        </div>
      </details>
      {{/each}}
    </div>
  </div>
  {{/each}}

  <!-- カテゴリなしのツール -->
  {{#ifNotEmpty uncategorizedTools}}
  <div class="mb-6">
    <h2 class="text-base font-semibold text-gray-900 mb-3">その他</h2>
    <div class="space-y-2">
      {{#each uncategorizedTools}}
      <div class="bg-white rounded-lg border border-gray-200 p-3">
        <div class="font-mono text-sm text-gray-900">{{this.name}}</div>
        <p class="text-sm text-gray-500 mt-1">{{this.description}}</p>
      </div>
      {{/each}}
    </div>
  </div>
  {{/ifNotEmpty}}
</div>
