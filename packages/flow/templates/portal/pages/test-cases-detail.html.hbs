<div class="max-w-3xl">
  <div class="mb-6">
    <a href="/test-cases/{{fileSlug}}" class="text-sm text-indigo-600 hover:underline">&larr; {{test.file}}</a>
    <h1 class="text-xl font-bold text-gray-900 mt-2">{{test.it}}</h1>
    <p class="text-sm text-gray-500 mt-1">{{test.describe}}</p>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
    {{#if test.description}}
    <div class="px-4 py-3">
      <div class="text-xs font-semibold text-gray-500 mb-1">説明</div>
      <div class="text-sm text-gray-900">{{test.description}}</div>
    </div>
    {{/if}}

    {{#if test.docs.purpose}}
    <div class="px-4 py-3">
      <div class="text-xs font-semibold text-gray-500 mb-1">目的</div>
      <div class="text-sm text-gray-900">{{test.docs.purpose}}</div>
    </div>
    {{/if}}

    {{#if test.docs.expected}}
    <div class="px-4 py-3">
      <div class="text-xs font-semibold text-gray-500 mb-1">期待する結果</div>
      <div class="text-sm text-gray-900">{{test.docs.expected}}</div>
    </div>
    {{/if}}

    {{#if test.bdd}}
    <div class="px-4 py-3">
      <div class="text-xs font-semibold text-gray-500 mb-2">BDD</div>
      {{#if test.bdd.given}}
      <div class="text-sm mb-1"><span class="font-medium text-blue-700">Given</span> {{test.bdd.given}}</div>
      {{/if}}
      {{#if test.bdd.when}}
      <div class="text-sm mb-1"><span class="font-medium text-amber-700">When</span> {{test.bdd.when}}</div>
      {{/if}}
      {{#if test.bdd.then}}
      <div class="text-sm"><span class="font-medium text-green-700">Then</span> {{test.bdd.then}}</div>
      {{/if}}
    </div>
    {{/if}}

    <div class="px-4 py-3 bg-gray-50 rounded-b-lg">
      <dl class="grid grid-cols-3 gap-4 text-sm">
        <div>
          <dt class="text-xs text-gray-500">フレームワーク</dt>
          <dd class="font-medium text-gray-900">{{test.framework}}</dd>
        </div>
        <div>
          <dt class="text-xs text-gray-500">行番号</dt>
          <dd class="font-medium text-gray-900">{{test.line}}</dd>
        </div>
        {{#if test.category}}
        <div>
          <dt class="text-xs text-gray-500">カテゴリ</dt>
          <dd class="font-medium text-gray-900">{{test.category}}</dd>
        </div>
        {{/if}}
      </dl>
    </div>
  </div>
</div>
