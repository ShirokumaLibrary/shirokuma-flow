<div class="max-w-4xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">{{moduleName}} - {{typeLabel}}</h1>
    <p class="text-gray-500 text-sm mt-1">{{totalItems}} 件</p>
  </div>

  {{#ifNotEmpty items}}
  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-2 font-medium text-gray-700">名前</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">説明</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each items}}
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-2">
            <a href="{{this.detailPath}}" class="font-medium text-indigo-600 hover:underline">{{this.name}}</a>
          </td>
          <td class="px-4 py-2 text-gray-500 truncate max-w-sm">{{this.description}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="text-center py-12 text-gray-400">アイテムがありません</div>
  {{/ifNotEmpty}}
</div>
