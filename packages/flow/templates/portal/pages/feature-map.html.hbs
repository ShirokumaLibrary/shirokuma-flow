<div class="max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">機能マップ</h1>
      <p class="text-gray-500 text-sm mt-1">{{totalModules}} モジュール &middot; {{totalItems}} アイテム</p>
    </div>
    <div class="text-xs text-gray-400">生成: {{generatedAt}}</div>
  </div>

  <div class="space-y-4">
    {{#each modules}}
    <details class="bg-white rounded-lg border border-gray-200 group">
      <summary class="flex items-center justify-between p-4 cursor-pointer list-none hover:bg-gray-50 rounded-lg">
        <div class="flex items-center gap-3">
          <span class="font-medium text-gray-900">{{this.name}}</span>
          {{#if this.description}}
          <span class="text-sm text-gray-500 truncate max-w-xs">{{this.description}}</span>
          {{/if}}
        </div>
        <div class="flex items-center gap-3">
          <div class="flex gap-2 text-xs text-gray-500">
            {{#if this.screenCount}}
            <span class="bg-blue-50 text-blue-700 px-2 py-0.5 rounded">画面 {{this.screenCount}}</span>
            {{/if}}
            {{#if this.componentCount}}
            <span class="bg-green-50 text-green-700 px-2 py-0.5 rounded">コンポーネント {{this.componentCount}}</span>
            {{/if}}
            {{#if this.actionCount}}
            <span class="bg-amber-50 text-amber-700 px-2 py-0.5 rounded">アクション {{this.actionCount}}</span>
            {{/if}}
            {{#if this.tableCount}}
            <span class="bg-purple-50 text-purple-700 px-2 py-0.5 rounded">テーブル {{this.tableCount}}</span>
            {{/if}}
          </div>
          <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </summary>

      <div class="px-4 pb-4 border-t border-gray-100 pt-3">
        {{#ifNotEmpty this.screens}}
        <div class="mb-3">
          <h3 class="text-xs font-semibold text-blue-700 uppercase mb-2">画面</h3>
          <ul class="grid grid-cols-2 gap-1">
            {{#each this.screens}}
            <li>
              <a href="/details/screen/{{urlEncode ../name}}/{{urlEncode this.name}}"
                 class="text-sm text-gray-700 hover:text-indigo-600 hover:underline block truncate">
                {{this.name}}
                {{#if this.route}}
                <span class="text-xs text-gray-400 ml-1">{{this.route}}</span>
                {{/if}}
              </a>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/ifNotEmpty}}

        {{#ifNotEmpty this.components}}
        <div class="mb-3">
          <h3 class="text-xs font-semibold text-green-700 uppercase mb-2">コンポーネント</h3>
          <ul class="grid grid-cols-2 gap-1">
            {{#each this.components}}
            <li>
              <a href="/details/component/{{urlEncode ../name}}/{{urlEncode this.name}}"
                 class="text-sm text-gray-700 hover:text-indigo-600 hover:underline block truncate">
                {{this.name}}
              </a>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/ifNotEmpty}}

        {{#ifNotEmpty this.actions}}
        <div class="mb-3">
          <h3 class="text-xs font-semibold text-amber-700 uppercase mb-2">アクション</h3>
          <ul class="grid grid-cols-2 gap-1">
            {{#each this.actions}}
            <li>
              <a href="/details/action/{{urlEncode ../name}}/{{urlEncode this.name}}"
                 class="text-sm text-gray-700 hover:text-indigo-600 hover:underline block truncate">
                {{this.name}}
              </a>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/ifNotEmpty}}
      </div>
    </details>
    {{/each}}
  </div>
</div>
