<div class="max-w-4xl">
  <div class="mb-6">
    <div class="text-sm text-gray-500">
      <a href="/details/{{type}}/{{urlEncode moduleName}}" class="text-indigo-600 hover:underline">{{moduleName}} ({{typeLabel}})</a>
      <span class="mx-1">/</span>
      <span>{{itemName}}</span>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">{{itemName}}</h1>
    {{#if detailItem.description}}
    <p class="text-gray-600 mt-1">{{detailItem.description}}</p>
    {{else if baseItem.description}}
    <p class="text-gray-600 mt-1">{{baseItem.description}}</p>
    {{/if}}
  </div>

  {{#if hasDetail}}
  <!-- JSDoc 情報 -->
  {{#if detailItem.jsDoc}}
  <div class="bg-white rounded-lg border border-gray-200 p-5 mb-4">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">JSDoc</h2>
    {{#if detailItem.jsDoc.description}}
    <p class="text-sm text-gray-600 mb-3">{{detailItem.jsDoc.description}}</p>
    {{/if}}
    {{#ifNotEmpty detailItem.jsDoc.params}}
    <div class="mb-3">
      <div class="text-xs font-semibold text-gray-500 mb-1">パラメーター</div>
      <table class="w-full text-sm">
        <tbody class="divide-y divide-gray-100">
          {{#each detailItem.jsDoc.params}}
          <tr>
            <td class="py-1 font-mono text-gray-900">{{this.name}}</td>
            {{#if this.type}}
            <td class="py-1 text-blue-700 px-2 font-mono">{{this.type}}</td>
            {{/if}}
            <td class="py-1 text-gray-500">{{this.description}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/ifNotEmpty}}
    {{#if detailItem.jsDoc.returns}}
    <div class="text-sm">
      <span class="text-xs font-semibold text-gray-500">戻り値: </span>
      <span class="text-gray-600">{{detailItem.jsDoc.returns}}</span>
    </div>
    {{/if}}
  </div>
  {{/if}}

  <!-- テストカバレッジ -->
  {{#if detailItem.testCoverage}}
  <div class="bg-white rounded-lg border border-gray-200 p-5 mb-4">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">テストカバレッジ</h2>
    <div class="flex items-center gap-4">
      <div class="text-2xl font-bold {{#if detailItem.testCoverage.hasTest}}text-green-600{{else}}text-gray-400{{/if}}">
        {{detailItem.testCoverage.coverageScore}}%
      </div>
      <div class="text-sm text-gray-500">
        {{detailItem.testCoverage.totalTests}} テスト
        {{#unless detailItem.testCoverage.hasTest}}
        <span class="text-amber-600 ml-2">テストなし</span>
        {{/unless}}
      </div>
    </div>
  </div>
  {{/if}}

  <!-- ソースコード -->
  {{#if detailItem.sourceCode}}
  <div class="bg-white rounded-lg border border-gray-200 p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">ソースコード</h2>
    <pre class="text-xs bg-gray-50 rounded p-3 overflow-x-auto font-mono whitespace-pre-wrap">{{detailItem.sourceCode}}</pre>
  </div>
  {{/if}}

  {{else}}
  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-amber-700">
    詳細データがありません。<code>shirokuma-flow generate details</code> を実行してください。
  </div>
  {{/if}}
</div>
