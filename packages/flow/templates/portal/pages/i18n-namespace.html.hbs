<div class="max-w-5xl">
  <div class="mb-6">
    <a href="/i18n" class="text-sm text-indigo-600 hover:underline">&larr; i18n 一覧</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">{{namespace.name}}</h1>
    <p class="text-gray-500 text-sm mt-1">{{namespace.stats.totalKeys}} キー &middot; 翻訳率: {{coveragePercent}}%</p>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200 sticky top-0">
        <tr>
          <th class="text-left px-4 py-2 font-medium text-gray-700">キー</th>
          {{#each locales}}
          <th class="text-left px-4 py-2 font-medium text-gray-700">{{this}}</th>
          {{/each}}
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each namespace.entries}}
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-2 font-mono text-xs text-gray-600 whitespace-nowrap">{{this.key}}</td>
          {{#each ../locales}}
          <td class="px-4 py-2 text-gray-900 max-w-xs truncate">
            {{#ifExists (lookup ../this.values this)}}
            {{lookup ../this.values this}}
            {{else}}
            <span class="text-red-400 text-xs">未翻訳</span>
            {{/ifExists}}
          </td>
          {{/each}}
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
