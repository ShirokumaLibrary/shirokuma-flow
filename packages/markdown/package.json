{
  "name": "@shirokuma-library/markdown",
  "version": "0.3.0-alpha.135",
  "description": "LLM-optimized Markdown document management CLI (shirokuma-md)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shirokuma-md": "bin/shirokuma-md"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "node --experimental-vm-modules ../../node_modules/jest-cli/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules ../../node_modules/jest-cli/bin/jest.js --coverage",
    "prepare": "tsc"
  },
  "keywords": [
    "markdown",
    "cli",
    "llm",
    "documentation"
  ],
  "author": "ShirokumaLibrary",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShirokumaLibrary/shirokuma-flow.git",
    "directory": "packages/markdown"
  },
  "homepage": "https://github.com/ShirokumaLibrary/shirokuma-flow#readme",
  "bugs": {
    "url": "https://github.com/ShirokumaLibrary/shirokuma-flow/issues"
  },
  "dependencies": {
    "@11ty/gray-matter": "^2.0.1",
    "@shirokuma-library/lint": "workspace:*",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "glob": "^13.0.3",
    "gpt-tokenizer": "^3.4.0",
    "markdown-it": "^14.1.1",
    "mdast-util-to-string": "^4.0.0",
    "minimatch": "^10.2.4",
    "ora": "^9.3.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vfile": "^6.0.3",
    "yaml": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@shirokuma-library/dev-preset": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.2.3",
    "@types/unist": "^3.0.3",
    "eslint": "^10.0.3",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
