{
  "name": "@shirokuma-library/portal",
  "version": "0.3.0-alpha.135",
  "description": "Human-facing documentation portal generation for shirokuma workflows.",
  "type": "module",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "shirokuma-portal": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shirokuma-library/codemap": "workspace:*",
    "@shirokuma-library/lint": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^13.0.3",
    "handlebars": "^4.7.8",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@shirokuma-library/dev-preset": "workspace:*",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShirokumaLibrary/shirokuma-flow.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
