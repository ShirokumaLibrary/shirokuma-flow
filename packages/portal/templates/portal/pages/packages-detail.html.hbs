<div class="max-w-4xl">
  <div class="mb-6">
    <a href="/packages" class="text-sm text-indigo-600 hover:underline">&larr; パッケージ一覧</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">{{package.name}}</h1>
    <div class="text-sm text-gray-400 font-mono">{{package.prefix}}</div>
    {{#if package.description}}
    <p class="text-gray-500 text-sm mt-2">{{package.description}}</p>
    {{/if}}
  </div>

  <div class="grid grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-3 text-center">
      <div class="text-xl font-bold text-gray-900">{{package.stats.moduleCount}}</div>
      <div class="text-xs text-gray-500">モジュール</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-3 text-center">
      <div class="text-xl font-bold text-gray-900">{{package.stats.exportCount}}</div>
      <div class="text-xs text-gray-500">エクスポート</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-3 text-center">
      <div class="text-xl font-bold text-gray-900">{{package.stats.typeCount}}</div>
      <div class="text-xs text-gray-500">型</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-3 text-center">
      <div class="text-xl font-bold text-gray-900">{{package.stats.functionCount}}</div>
      <div class="text-xs text-gray-500">関数</div>
    </div>
  </div>

  <div class="space-y-4">
    {{#each package.modules}}
    <details class="bg-white rounded-lg border border-gray-200 group">
      <summary class="flex items-center justify-between p-4 cursor-pointer list-none hover:bg-gray-50 rounded-lg">
        <div>
          <span class="font-medium text-gray-900">{{this.name}}</span>
          {{#if this.description}}
          <span class="text-sm text-gray-500 ml-2">{{this.description}}</span>
          {{/if}}
        </div>
        <span class="text-xs text-gray-400">{{length this.exports}} エクスポート</span>
      </summary>
      <div class="px-4 pb-4 border-t border-gray-100 pt-3">
        {{#ifNotEmpty this.exports}}
        <ul class="space-y-1">
          {{#each this.exports}}
          <li class="flex items-start gap-2 text-sm">
            <span class="text-xs bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded font-mono flex-shrink-0 mt-0.5">{{this.kind}}</span>
            <div>
              <span class="font-mono text-gray-900">{{this.name}}</span>
              {{#if this.description}}
              <span class="text-gray-500 ml-2">{{this.description}}</span>
              {{/if}}
            </div>
          </li>
          {{/each}}
        </ul>
        {{/ifNotEmpty}}
      </div>
    </details>
    {{/each}}
  </div>
</div>
