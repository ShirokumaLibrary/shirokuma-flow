<div class="max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">テストケース</h1>
      <p class="text-gray-500 text-sm mt-1">{{summary.totalTests}} 件 (Jest: {{summary.jestTests}} / Playwright: {{summary.playwrightTests}})</p>
    </div>
    <div class="text-xs text-gray-400">生成: {{generatedAt}}</div>
  </div>

  <!-- 統計 -->
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
      <div class="text-2xl font-bold text-gray-900">{{summary.totalTests}}</div>
      <div class="text-sm text-gray-500">合計</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
      <div class="text-2xl font-bold text-blue-600">{{summary.jestTests}}</div>
      <div class="text-sm text-gray-500">Jest</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
      <div class="text-2xl font-bold text-green-600">{{summary.playwrightTests}}</div>
      <div class="text-sm text-gray-500">Playwright</div>
    </div>
  </div>

  <!-- ファイル一覧 -->
  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-2 font-medium text-gray-700">ファイル</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">フレームワーク</th>
          <th class="text-right px-4 py-2 font-medium text-gray-700">describe</th>
          <th class="text-right px-4 py-2 font-medium text-gray-700">テスト数</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each fileStats}}
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-2">
            <a href="/test-cases/{{this.fileSlug}}" class="text-indigo-600 hover:underline font-mono text-xs">
              {{this.file}}
            </a>
          </td>
          <td class="px-4 py-2">
            <span class="text-xs {{#eq this.framework 'playwright'}}bg-green-50 text-green-700{{else}}bg-blue-50 text-blue-700{{/eq}} px-2 py-0.5 rounded">
              {{this.framework}}
            </span>
          </td>
          <td class="px-4 py-2 text-right text-gray-600">{{this.describeCount}}</td>
          <td class="px-4 py-2 text-right font-medium text-gray-900">{{this.testCount}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
