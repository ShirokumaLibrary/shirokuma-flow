<!DOCTYPE html>
<html lang="ja" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
  <script src="https://cdn.tailwindcss.com/3.4.19"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            accent: '#6366f1',
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/assets/portal.css" />
</head>
<body class="h-full bg-gray-50 text-gray-900 {{bodyClass}}">

  <!-- モバイルオーバーレイ -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-20 hidden lg:hidden" onclick="toggleSidebar()"></div>

  <div class="flex h-full">
    <!-- サイドバー -->
    <aside id="sidebar" class="fixed inset-y-0 left-0 w-64 bg-white border-r border-gray-200 z-30 transform -translate-x-full lg:translate-x-0 lg:static lg:inset-0 transition-transform duration-200">
      <div class="flex items-center h-16 px-4 border-b border-gray-200">
        <a href="/" class="flex items-center gap-2 font-bold text-gray-900 truncate">
          <span class="text-indigo-600">&#9632;</span>
          <span class="truncate">{{projectName}}</span>
        </a>
      </div>
      <nav class="overflow-y-auto h-[calc(100%-4rem)] py-4">
        {{> sidebar sidebarSections=sidebarSections currentPath=currentPath}}
      </nav>
    </aside>

    <!-- メインコンテンツ -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
      <!-- トップバー -->
      <header class="h-16 bg-white border-b border-gray-200 flex items-center px-4 gap-4">
        <button
          onclick="toggleSidebar()"
          class="lg:hidden p-2 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        {{#ifNotEmpty breadcrumbs}}
        <nav class="flex items-center gap-1 text-sm text-gray-500 min-w-0">
          <a href="/" class="hover:text-gray-700">ホーム</a>
          {{#each breadcrumbs}}
          <span>/</span>
          {{#if this.href}}
          <a href="{{this.href}}" class="hover:text-gray-700 truncate">{{this.label}}</a>
          {{else}}
          <span class="text-gray-900 truncate">{{this.label}}</span>
          {{/if}}
          {{/each}}
        </nav>
        {{/ifNotEmpty}}

        <div class="ml-auto">
          <button
            onclick="openSearch()"
            class="flex items-center gap-2 px-3 py-1.5 text-sm text-gray-500 bg-gray-100 hover:bg-gray-200 rounded-md transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <span>検索...</span>
            <kbd class="text-xs bg-white border border-gray-200 rounded px-1">⌘K</kbd>
          </button>
        </div>
      </header>

      <!-- ページコンテンツ -->
      <main class="flex-1 overflow-y-auto p-6">
        {{{content}}}
      </main>

      <!-- フッター -->
      <footer class="border-t border-gray-200 px-6 py-3 text-xs text-gray-500 bg-white">
        <span>{{projectName}} ドキュメントポータル &copy; {{currentYear}}</span>
      </footer>
    </div>
  </div>

  <!-- 検索モーダル -->
  <div id="search-modal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black bg-opacity-50" onclick="closeSearch()"></div>
    <div class="fixed top-1/4 left-1/2 -translate-x-1/2 w-full max-w-xl bg-white rounded-xl shadow-2xl overflow-hidden">
      <div class="flex items-center border-b border-gray-200 px-4">
        <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="検索..."
          class="flex-1 px-3 py-4 text-sm outline-none"
          oninput="onSearchInput(this.value)"
          onkeydown="onSearchKeydown(event)"
        />
        <button onclick="closeSearch()" class="text-gray-400 hover:text-gray-600 text-sm">ESC</button>
      </div>
      <div id="search-results" class="max-h-96 overflow-y-auto py-2">
        <div class="px-4 py-8 text-center text-gray-400 text-sm">キーワードを入力してください</div>
      </div>
    </div>
  </div>

  <script src="/assets/portal.js"></script>
  {{{extraScripts}}}
</body>
</html>
