{{#each sidebarSections}}
<div class="px-3 mb-4">
  <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1 px-3">{{this.title}}</div>
  <ul class="space-y-0.5">
    {{#each this.links}}
    <li>
      <a
        href="{{this.href}}"
        class="flex items-center justify-between gap-2 px-3 py-1.5 text-sm rounded-md transition-colors
          {{#eq this.href ../currentPath}}bg-indigo-50 text-indigo-700 font-medium{{else}}text-gray-700 hover:bg-gray-100{{/eq}}"
      >
        <span class="truncate">{{this.label}}</span>
        {{#ifExists this.count}}
        <span class="text-xs text-gray-400 flex-shrink-0">{{this.count}}</span>
        {{/ifExists}}
      </a>
      {{#ifNotEmpty this.children}}
      <ul class="ml-3 mt-0.5 space-y-0.5">
        {{#each this.children}}
        <li>
          <a
            href="{{this.href}}"
            class="flex items-center justify-between gap-2 px-3 py-1 text-xs rounded-md transition-colors text-gray-600 hover:bg-gray-100"
          >
            <span class="truncate">{{this.label}}</span>
            {{#ifExists this.count}}
            <span class="text-gray-400">{{this.count}}</span>
            {{/ifExists}}
          </a>
        </li>
        {{/each}}
      </ul>
      {{/ifNotEmpty}}
    </li>
    {{/each}}
  </ul>
</div>
{{/each}}
