#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/projects/shirokuma-docs/packages/codemap/dist/node_modules:/home/ubuntu/projects/shirokuma-docs/packages/codemap/node_modules:/home/ubuntu/projects/shirokuma-docs/packages/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules:/home/ubuntu/projects/node_modules:/home/ubuntu/node_modules:/home/node_modules:/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/projects/shirokuma-docs/packages/codemap/dist/node_modules:/home/ubuntu/projects/shirokuma-docs/packages/codemap/node_modules:/home/ubuntu/projects/shirokuma-docs/packages/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules:/home/ubuntu/projects/node_modules:/home/ubuntu/node_modules:/home/node_modules:/node_modules:/home/ubuntu/projects/shirokuma-docs/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../codemap/dist/cli.js" "$@"
else
  exec node  "$basedir/../../../codemap/dist/cli.js" "$@"
fi
