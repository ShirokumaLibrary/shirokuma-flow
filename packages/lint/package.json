{
  "name": "@shirokuma-library/lint",
  "version": "0.3.0-alpha.149",
  "description": "File-level lint checks for AI-first documentation and code structure (tests/coverage/docs/code/annotations/structure/workflow/security).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShirokumaLibrary/shirokuma-flow.git",
    "directory": "packages/lint"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./errors": {
      "types": "./dist/exit-code.d.ts",
      "import": "./dist/exit-code.js"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js"
    },
    "./brace-matching": {
      "types": "./dist/brace-matching.d.ts",
      "import": "./dist/brace-matching.js"
    },
    "./cli-logger": {
      "types": "./dist/cli-logger.d.ts",
      "import": "./dist/cli-logger.js"
    },
    "./commander-opts": {
      "types": "./dist/commander-opts.d.ts",
      "import": "./dist/commander-opts.js"
    },
    "./spawn-async": {
      "types": "./dist/spawn-async.d.ts",
      "import": "./dist/spawn-async.js"
    },
    "./formatters": {
      "types": "./dist/formatters.d.ts",
      "import": "./dist/formatters.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "import": "./dist/i18n.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./help-json": {
      "types": "./dist/help-json.d.ts",
      "import": "./dist/help-json.js"
    }
  },
  "bin": {
    "shirokuma-lint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "i18n",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^13.0.3",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@shirokuma-library/dev-preset": "workspace:*",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
