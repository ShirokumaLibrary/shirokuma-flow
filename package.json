{
  "name": "shirokuma-docs-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "prepare": "[ -d .githooks ] && git config core.hooksPath .githooks || true",
    "postinstall": "[ -d plugin ] && [ -z \"$CI\" ] && ./scripts/switch-plugin.sh dev > /dev/null 2>&1 || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<4": ">=3.1.4",
      "minimatch@>=9.0.0 <10": ">=9.0.7",
      "flatted@<=3.4.1": ">=3.4.2",
      "handlebars@>=4.0.0 <=4.7.8": ">=4.7.9",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "handlebars@>=4.0.0 <4.7.9": ">=4.7.9",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "handlebars@>=4.6.0 <=4.7.8": ">=4.7.9"
    }
  }
}
