# Dependencies
node_modules/

# Build output
dist/

# Backup files
*.backup

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# Generated docs (optional)
docs/generated/
docs/portal/
research/

# Portal build cache and artifacts
portal/.next/
portal/out/
portal/data/*.json
portal/node_modules/
portal/home/
portal/pnpm-lock.yaml
portal/*.tsbuildinfo
portal/next-env.d.ts

# Claude Code (local settings)
.claude/settings.local.json
.claude/sessions/
.claude/scheduled_tasks.lock

# Installed plugin artifacts (source: plugin/)
# Load via: claude --plugin-dir .claude/plugins/shirokuma-skills-en

# Plan files (generated by Claude Code)
.claude/plans/

# Agent memory (generated by subagents)
# `**/` catches subagents that accidentally write to CWD-relative paths
# (e.g., packages/flow/.claude/agent-memory/ when worker runs `cd packages/flow`)
**/.claude/agent-memory/

# Test output (created by test runners, cleaned per-subdirectory)
.test-output/

# shirokuma-docs generated artifacts (plugin rules, docs cache, GitHub cache)
# `**/` matches both root and nested locations (e.g., packages/*/.shirokuma/)
**/.shirokuma/rules/shirokuma/
**/.shirokuma/contexts/
**/.shirokuma/github/
**/.shirokuma/cache/
**/.shirokuma/snapshots/

tmp/
tmp/*
